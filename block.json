{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-theme-fse/shape-section",
	"version": "1.0",
	"title": "Shape Section",
	"category": "design",
	"icon": "cover-image",
	"description": "A section with background image and flexible content alignment.",
	"keywords": [ "section", "shape", "svg", "image", "background" ],
	"textdomain": "wp-theme-fse",
	"attributes": {
		"backgroundImage": {
			"type": "object",
			"default": {
				"id": null,
				"url": "",
				"alt": "",
				"srcset": "",
				"sizes": "",
				"width": null,
				"height": null
			}
		},
		"imagePosition": {
			"type": "object",
			"default": null
		},
		"mobileBackgroundImage": {
			"type": "object",
			"default": {
				"id": null,
				"url": "",
				"alt": "",
				"srcset": "",
				"sizes": "",
				"width": null,
				"height": null
			}
		},
		"mobileImagePosition": {
			"type": "object",
			"default": null
		},
		"contentAlignment": {
			"type": "string",
			"default": "left"
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"color": {
			"background": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}